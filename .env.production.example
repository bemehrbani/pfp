# Django
SECRET_KEY=change-this-to-a-secure-random-key
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,backend,localhost
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database
POSTGRES_DB=pfp_campaign
POSTGRES_USER=pfp_user
POSTGRES_PASSWORD=change-this-to-a-secure-password
DATABASE_URL=postgres://pfp_user:change-this-to-a-secure-password@postgres:5432/pfp_campaign

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/bot-webhook

# Frontend
REACT_APP_API_URL=https://yourdomain.com/api

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@peopleforpeace.org

# Domain for Traefik
DOMAIN_NAME=yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# Security - generate with: openssl rand -base64 32
DJANGO_SECURE_HSTS_SECONDS=31536000