# Telegram Bot Configuration

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Webhook settings (for production)
TELEGRAM_WEBHOOK_URL=https://your-domain.com
TELEGRAM_WEBHOOK_PORT=8443

# Django backend URL
DJANGO_API_URL=http://localhost:8000/api
DJANGO_SECRET_KEY=development-secret-key

# Bot settings
BOT_ADMIN_IDS=123456789,987654321  # Comma-separated list of admin user IDs
BOT_LOGGING_LEVEL=INFO

# Database (shared with Django)
DATABASE_URL=postgres://pfp_user:pfp_password@localhost:5432/pfp_campaign
REDIS_URL=redis://localhost:6379/0